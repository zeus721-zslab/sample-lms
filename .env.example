# =============================================
# zslab LMS — Environment Variables
# cp .env.example .env && 값 채운 후 사용
# =============================================

# ── App ──────────────────────────────────────
APP_NAME="zslab LMS"
APP_ENV=production          # local | production
APP_DEBUG=false
APP_URL=https://zslab-lms.duckdns.org

# ── Database (기존 zslab_mariadb 재활용) ──────
DB_CONNECTION=mysql
DB_HOST=zslab_mariadb
DB_PORT=3306
DB_DATABASE=zslab_lms
DB_USERNAME=zslab_lms
DB_PASSWORD=your_db_password

# ── Redis (기존 zslab_redis 재활용) ───────────
REDIS_HOST=zslab_redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Elasticsearch (기존 재활용) ───────────────
ELASTICSEARCH_HOST=zslab_elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_PREFIX=lms_

# ── Queue / Cache / Session ───────────────────
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Mail ──────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@zslab-lms.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── JWT / Auth ────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_TTL=1440

# ── Socket.io (Node realtime) ─────────────────
SOCKET_PORT=3001
SOCKET_CORS_ORIGIN=https://zslab-lms.duckdns.org

# ── Next.js (공개 환경변수) ───────────────────
NEXT_PUBLIC_API_URL=https://zslab-lms.duckdns.org/api
NEXT_PUBLIC_SOCKET_URL=https://zslab-lms.duckdns.org/ws
NEXT_PUBLIC_CHAT_URL=https://zslab-lms.duckdns.org/chat

# ── 1:1 채팅 서버 (내부) ─────────────────────
CHAT_URL=http://lms_chat:3002
CHAT_INTERNAL_SECRET=your_chat_internal_secret_here

# ── FrankenPHP ───────────────────────────────
FRANKENPHP_WORKER_COUNT=4
SERVER_NAME=:80

# ── Docker image tags ─────────────────────────
PHP_IMAGE_TAG=latest
NODE_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
